<%- include('header') %>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
  <h2>User Management</h2>
  <a href="/users/create" class="btn btn-primary">+ Add New User</a>
</div>

<div class="card" style="padding: 0; overflow: hidden;">
  <table style="width: 100%; border-collapse: collapse; text-align: left;">
    <thead style="background-color: rgba(30, 41, 59, 0.5); border-bottom: 1px solid var(--border);">
      <tr>
        <th style="padding: 1rem; color: var(--text-muted); font-weight: 600; font-size: 0.875rem;">Profile</th>
        <th style="padding: 1rem; color: var(--text-muted); font-weight: 600; font-size: 0.875rem;">Name</th>
        <th style="padding: 1rem; color: var(--text-muted); font-weight: 600; font-size: 0.875rem;">Email</th>
        <th style="padding: 1rem; color: var(--text-muted); font-weight: 600; font-size: 0.875rem;">Role</th>
        <th style="padding: 1rem; color: var(--text-muted); font-weight: 600; font-size: 0.875rem; text-align: right;">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (users.length === 0) { %>
        <tr>
          <td colspan="5" style="padding: 2rem; text-align: center; color: var(--text-muted);">No users found. Create one!</td>
        </tr>
      <% } else { %>
        <% users.forEach(function(user) { %>
          <tr style="border-bottom: 1px solid var(--border); transition: background-color 0.2s;">
            <td style="padding: 1rem;">
              <% if (user.profile_image_url) { %>
                <img src="<%= user.profile_image_url %>" alt="<%= user.name %>" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover; border: 2px solid var(--border);">
              <% } else { %>
                <div style="width: 40px; height: 40px; border-radius: 50%; background-color: var(--border); display: flex; align-items: center; justify-content: center; font-weight: bold;"><%= user.name.charAt(0).toUpperCase() %></div>
              <% } %>
            </td>
            <td style="padding: 1rem; font-weight: 500;"><%= user.name %></td>
            <td style="padding: 1rem; color: var(--text-muted);"><%= user.email %></td>
            <td style="padding: 1rem;">
              <span style="background-color: <%= user.role === 'admin' ? 'rgba(79, 70, 229, 0.2)' : 'rgba(148, 163, 184, 0.1)' %>; color: <%= user.role === 'admin' ? '#818CF8' : '#CBD5E1' %>; padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 600;"><%= user.role %></span>
            </td>
            <td style="padding: 1rem; text-align: right; display: flex; gap: 0.5rem; justify-content: flex-end;">
              <a href="/users/<%= user.id %>/edit" class="btn" style="background-color: var(--border); color: white;">Edit</a>
              <form action="/users/<%= user.id %>?_method=DELETE" method="POST" style="margin: 0; display: inline;" onsubmit="return confirm('Are you sure you want to delete this user?');">
                <button type="submit" class="btn btn-danger">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      <% } %>
    </tbody>
  </table>
</div>

<%- include('footer') %>
